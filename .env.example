PORT=8080
DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/haru?sslmode=disable
DB_DRIVER=sqlite
LOG_LEVEL=info

# Gemini API
GEMINI_API_KEY=your-api-key-here
GEMINI_MODEL=gemini-2.5-flash
DEFAULT_TIMEZONE=Asia/Seoul

# JWT
JWT_SECRET=your-secret-key-at-least-32-chars

# Apple Sign In
APPLE_CLIENT_ID=com.example.app
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_REDIRECT_URI=

# Kakao
KAKAO_CLIENT_ID=your-kakao-rest-api-key
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=

# Docker Compose
POSTGRES_USER=USER
POSTGRES_PASSWORD=PASSWORD
POSTGRES_DB=DATABASE
